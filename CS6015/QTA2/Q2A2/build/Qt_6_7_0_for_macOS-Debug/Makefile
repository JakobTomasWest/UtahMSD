	@test -d Q2A2.app/Contents || mkdir -p Q2A2.app/Contents
	@$(DEL_FILE) Q2A2.app/Contents/PkgInfo
	@echo "APPL????" > Q2A2.app/Contents/PkgInfo
Q2A2.app/Contents/Info.plist: 
	@test -d Q2A2.app/Contents || mkdir -p Q2A2.app/Contents
	@$(DEL_FILE) Q2A2.app/Contents/Info.plist
	@plutil -convert xml1 -o - /Users/jakobwest/Qt/6.7.0/macos/mkspecs/macx-clang/Info.plist.app | sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,cpp.Q2A2,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},cpp.Q2A2,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},11.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,\$${IOS_LAUNCH_SCREEN},LaunchScreen,g" -e "s,@ICON@,,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},,g" -e "s,@EXECUTABLE@,Q2A2,g" -e "s,@LIBRARY@,Q2A2,g" -e "s,\$${EXECUTABLE_NAME},Q2A2,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" >Q2A2.app/Contents/Info.plist

